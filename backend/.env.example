# Copy to .env for local overrides, or set these in Render → Environment

# ── Database (Neon PostgreSQL) ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxx.us-east-1.aws.neon.tech/eid_cricket_fest?sslmode=require
SPRING_DATASOURCE_USERNAME=your_neon_user
SPRING_DATASOURCE_PASSWORD=your_neon_password

# ── CORS (set to your Vercel frontend URL) ───────────────────────────────────
CORS_ALLOWED_ORIGIN=https://eid-cricket-fest.vercel.app

# ── Server port (Render sets this automatically) ─────────────────────────────
# PORT=10000
